@model CategoryVM

<div class="d-flex justify-content-center">
	<h1 class="text-success">Edit Category</h1>
</div>
<br />
<hr />
<br />

@using (Html.BeginForm("EditCategory", "Category", FormMethod.Post))
{
	@Html.HiddenFor(m => m.Id)

	<div class="mb-3 form-group">
		@Html.LabelFor(m => m.Name,  new { @class = "form-label" })
		@Html.TextBoxFor(m => m.Name, new { @class = "form-control", required = "required" })
	</div>

	<div class="d-flex justify-content-center gap-3">
		<input type="submit" class="btn btn-warning" value="Update Category" />
		@Html.ActionLink("Cancel", "Index", "Category" , null, new { @class = "btn btn-secondary" } )
	</div>
}
