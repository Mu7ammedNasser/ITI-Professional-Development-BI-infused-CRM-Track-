@using MVC_day04_lab.ViewModels.Category
@model IEnumerable<CategoryVM>
<h2>Category List</h2>
<table class="table">
	<thead>
		<tr>
			<th>Id</th>
			<th>Name</th>
			<th>Actions</th>
		</tr>
	</thead>
	<tbody>
		@foreach (var category in Model)
		{
			<tr>
				<td>@category.Id</td>
				<td>@category.Name</td>
				<td>
					@Html.ActionLink(
										"Edit",
										"EditCategory",
										"Category",
										new { id = category.Id },
										new { @class = "btn btn-primary" }
										)

					@Html.ActionLink(
										"Delete",
										"DeleteCategory",
										"Category",
										new { id = category.Id },
										new
										{
											@class = "btn btn-danger",
											onclick = "return confirm('Are you sure you want to delete this category?');"
										}
										)
				</td>
			</tr>
		}
	</tbody>
	<tfoot>
		<tr>
			<td colspan="3">
				@Html.ActionLink("Add New Category", "CreateCategory", "Category", null, new { @class = "btn btn-success" })
			</td>
		</tr>
	</tfoot>
</table>

@section Ads {

	<div class=" text-center container alert alert-info" role="alert">
		<p>from Category</p>
		<p>
			This is an advertisement section. You can place your ads here.
		</p>

	</div>
}
