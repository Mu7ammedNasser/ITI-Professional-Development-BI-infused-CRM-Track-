@model ProductCategoriesVM

<div class="d-flex justify-content-center">
	<h1>All Product Categories</h1>
</div>

<br />
<hr />
<br />


<div class="mb-3 form-group">
	<label asp-for="CategoryId" class="form-label">Category</label>
	<select id="categoryDropDown" asp-for="CategoryId" asp-items="Model.Categories" class="form-select" required>
		<option value="">-- Select Category --</option>
	</select>
	<span asp-validation-for="CategoryId" class="text-danger"></span>
</div>

<div id="productsTableBody">
	@* Product table will be shown here *@
</div>

@section Scripts {
	<script>
		$(document).ready(function (){
			$("#categoryDropDown").change(function(){
				var catId = $(this).val();
				console.log(`selected department Id = ${catId}`);
				if(catId !== ""){
					$.ajax({
						url:'/productCategory/GetProductByCatId',
						type: 'GET',
						data : {catId: catId },
						success: function(data){
							$("#productsTableBody").html(data);
						},
						error: function(){
							console.log("error")
						}
					});

				}else{
					$("#productsTableBody").html("");
				}
			});
		});
	</script>
}

