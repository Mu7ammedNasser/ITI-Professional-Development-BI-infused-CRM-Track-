@model Product

<div class="d-flex justify-content-center">
    <h1 class="text-success">Create Product</h1>
</div>


<br />
<hr />
<br />

<form action="~/Product/ActualCreate">

    <div class="mb-3 form-group">
        <label for="Id" class="form-label">Id</label>
        <input type="number" class="form-control" id="Id" name="Id" required  />
    </div>

    <div class="mb-3 form-group">
        <label for="Name" class="form-label">Title</label>
        <input type="text" class="form-control" id="Title" name="Title" required />
    </div>

    <div class="mb-3 form-group">
        <label for="Age" class="form-label">Description</label>
        <input type="text" class="form-control" id="Description" name="Description" required />
    </div>

    <div class="mb-3 form-group">
        <label for="Salary" class="form-label">Price</label>
        <input type="number" class="form-control" id="Price" name="Price" required />
    </div>

    <div class="mb-3 form-group">
        <label for="Salary" class="form-label">Count</label>
        <input type="number" class="form-control" id="Count" name="Count" required />
    </div>

    <div class="d-flex justify-content-center gap-3">
        <input type="submit" class="btn btn-success" value="Create Product" />
        <a href="~/Product/GetAll" class="btn btn-secondary">Cancel</a>
    </div>

</form>