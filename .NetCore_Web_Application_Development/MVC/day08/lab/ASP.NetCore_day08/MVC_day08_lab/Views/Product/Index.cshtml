@model IEnumerable<ProductsDisplayVM>

<div class="d-flex justify-content-center">
	<h2 class="text-success">All Products</h2>
</div>

<br />
<hr />
<br />

<table class="table text-center">
	<thead>
		<tr>
			<th scope="col">Id</th>
			<th scope="col">Name</th>
			<th scope="col">Price</th>
			<th scope="col">Description</th>
			<th scope="col">Category</th>
			<th scope="col">Image</th>
			<th scope="col">Actions</th>
		</tr>
	</thead>
	<tbody>
		@foreach (var product in Model)
		{
			<tr>
				<th scope="row">@product.Id</th>
				<th scope="row">@product.Name</th>
				<th scope="row">@product.Price</th>
				<th scope="row">@product.Description</th>
				<th scope="row">@product.CategoryName</th>
				<th scope="row">
					<img src="/Images/Products/@product.ImageURL" alt="@product.Name" width="100" height="100" class="img-thumbnail" />
				</th>
				<th scope="row">
					<!-- Details -->
					<a asp-action="ProductDetails"
					   asp-controller="Product"
					   asp-route-id="@product.Id"
					   class="btn btn-primary">
						Details
					</a>

					<!-- Edit -->
					<a asp-action="Edit"
					   asp-controller="Product"
					   asp-route-id="@product.Id"
					   class="btn btn-outline-secondary">
						Edit
					</a>

					<!-- Delete -->
					<a asp-action="Delete"
					   asp-controller="Product"
					   asp-route-id="@product.Id"
					   onclick="return confirm('Are you sure you want to delete this product?')"
					   class="btn btn-outline-danger">
						Delete
					</a>
				</th>
			</tr>
		}
	</tbody>
	<tfoot>
		<a href="~/Product/CreateProduct" class="btn btn-success">Create New Product</a>
	</tfoot>
</table>

@section Ads {

	<div class="text-center container alert alert-info" role="alert">
		<p>from Products</p>
		<p>
			This is an advertisement section. You can place your ads here.
		</p>

	</div>
}


