@model Category

<div class="d-flex justify-content-center">
	<h1 class="text-success">Create Category<h1>

</div>

<br />
<hr />
<br />

<form action="~/Category/CreateCategory" method="post">
	<div class="mb-3 form-group">
		<label for="Name" class="form-label">Name</label>
		<input type="text" class="form-control" id="Name" name="Name" required />
	</div>
	<div class="d-flex justify-content-center gap-3">
		<input type="submit" class="btn btn-success" value="Create Category" />
		<a href="~/Category/Index" class="btn btn-secondary">Cancel</a>
	</div>
</form>