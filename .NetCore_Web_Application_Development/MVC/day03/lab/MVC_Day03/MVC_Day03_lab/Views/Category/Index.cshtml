@model IEnumerable<Category>
<h2>Category List</h2>
<table class="table">
	<thead>
		<tr>
			<th>Id</th>
			<th>Name</th>
			<th>Actions</th>
		</tr>
	</thead>
	<tbody>
		@foreach (var category in Model)
		{
			<tr>
				<td>@category.Id</td>
				<td>@category.Name</td>
				<td>
					<a href="~/Category/EditCategory/@category.Id" class="btn btn-primary">Edit</a>
					<a href="~/Category/DeleteCategory/@category.Id"
					   class="btn btn-danger"
					   onclick="return confirm('Are you sure you want to delete this category?');">
						Delete
					</a>
				</td>
			</tr>
		}
	</tbody>
	<tfoot>
		<tr>
			<td colspan="3">
				<a href="~/Category/CreateCategory" class="btn btn-success">Add New Category</a>
			</td>
		</tr>
	</tfoot>
</table>