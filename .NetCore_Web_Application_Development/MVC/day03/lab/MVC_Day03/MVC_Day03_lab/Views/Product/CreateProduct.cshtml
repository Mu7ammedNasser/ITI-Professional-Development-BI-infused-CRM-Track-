@model Product

<div class="d-flex justify-content-center">
	<h1 class="text-success">Create Product<h1>
</div>

<br />
<hr />
<br />

<form action="~/Product/CreateProduct" method="post">

	<div class="mb-3 form-group">
		<label for="Name" class="form-label">Name</label>
		<input type="text" class="form-control" id="Name" name="Name" required />
	</div>

	<div class="mb-3 form-group">
		<label for="Age" class="form-label">Price</label>
		<input type="number" class="form-control" id="Price" name="Price" required />
	</div>
	
	<div class="mb-3 form-group">
		<label for="Salary" class="form-label">Description</label>
		<input type="text" class="form-control" id="Salary" name="Description" required />
	</div>
	<div class="mb-3 form-group">
		<label for="Salary" class="form-label">Count</label>
		<input type="number" class="form-control" id="Count" name="Count" required />
	</div>
	<div class="mb-3 form-group">
		<label for="DepartmentId" class="form-label">Category</label>
		<select class="form-select" id="CategoryID" name="CategoryId" required>
			@foreach (var cat in ViewBag.Categories)
			{
				<option value="@cat.Value">@cat.Text</option>
			}
		</select>
	</div>

	<div class="d-flex justify-content-center gap-3">
		<input type="submit" class="btn btn-success" value="Create Product" />
		<a href="~/Product/Index" class="btn btn-secondary">Cancel</a>
	</div>

</form>